{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",

    "Serilog": {
        "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.OpenTelemetry" ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Information"
            }
        },
        "WriteTo": [
            { "Name": "Console" }
        ],
        "Enrich": [ "WithMachineName", "WithProcessId", "WithThreadId" ]
    },

    "AccessTokenConfiguration": {
        "LifetimeSeconds": 900
    }
}

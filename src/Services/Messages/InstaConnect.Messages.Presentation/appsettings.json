{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "DatabaseOptions": {
        "ConnectionString": "Server=sqlserver;Database=instaconnect.messages;User Id=sa;Password=password123!;MultipleActiveResultSets=true;TrustServerCertificate=True;"
    },
    "CorsOptions": {
        "AllowedOrigins": "gateway-svc:5100"
    },
    "MessageBrokerOptions": {
        "Host": "amqp://rabbitmq:5672",
        "Username": "guest",
        "Password": "guest"
    },
    "AdminOptions": {
        "Email": "admin@instaconnect.com",
        "Password": "SecureAdminPass123!"
    },
    "AccessTokenOptions": {
        "Issuer": "http://identity-svc:5200",
        "Audience": "http://gateway-svc:5100",
        "SecurityKey": "6R9f6d1Y4Z$0^8Y&S2e3nF4*G6u7D0#L",
        "LifetimeSeconds": 900
    },
    "Serilog": {
        "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.OpenTelemetry" ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Information"
            }
        },
        "WriteTo": [
            { "Name": "Console" },
            {
                "Name": "OpenTelemetry",
                "Args": {
                    "Endpoint": "http://grafana:4317",
                    "Protocol": "Grpc",
                    "ResourceAttributes": {
                        "deployment.environment": "development"
                    }
                }
            }
        ],
        "Enrich": [ "WithMachineName", "WithProcessId", "WithThreadId" ]
    },
    "OpenTelemetryOptions": {
        "Endpoint": "http://otel-lgtm:4317"
    }
}

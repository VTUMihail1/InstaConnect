{
    "Serilog": {
        "WriteTo": [
            { "Name": "Console" },
            {
                "Name": "OpenTelemetry",
                "Args": {
                    "Endpoint": "http://grafana:4317",
                    "Protocol": "Grpc",
                    "ResourceAttributes": {
                        "deployment.environment": "docker"
                    }
                }
            }
        ]
    },

    "OpenTelemetryConfiguration": {
        "Endpoint": "http://otel-lgtm:4317"
    },

    "CorsConfiguration": {
        "AllowedOrigins": "http://gateway-svc:5100"
    },

    "AccessTokenConfiguration": {
        "Issuer": "http://identity-svc:5200",
        "Audience": "http://gateway-svc:5100"
    }
}

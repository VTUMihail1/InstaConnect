{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"AllowedHosts": "*",

	"Serilog": {
		"Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.OpenTelemetry" ],
		"MinimumLevel": {
			"Default": "Information",
			"Override": {
				"Microsoft": "Information"
			}
		},
		"WriteTo": [
			{ "Name": "Console" }
		],
		"Enrich": [ "WithMachineName", "WithProcessId", "WithThreadId" ]
	},

	"AccessTokenConfiguration": {
		"ValidateIssuer": true,
		"ValidateAudience": true,
		"ValidateLifetime": true,
		"ValidateIssuerSigningKey": true,
		"ClockSkewSeconds": 0,
		"LifetimeSeconds": 900
	},

	"EmailConfirmationTokenConfiguration": {
		"LifetimeSeconds": 10000
	},

	"ForgotPasswordTokenConfiguration": {
		"LifetimeSeconds": 10000
	},

	"RefreshTokenConfiguration": {
		"LifetimeSeconds": 10000
	},

	"AdminConfiguration": {
		"Name": "AdminName",
		"FirstName": "AdminFirstName",
		"LastName": "AdminLastName"
	}
}

{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "Serilog": {
        "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.OpenTelemetry" ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Information"
            }
        },
        "WriteTo": [
            { "Name": "Console" },
            {
                "Name": "OpenTelemetry",
                "Args": {
                    "Endpoint": "http://grafana:4317",
                    "Protocol": "Grpc",
                    "ResourceAttributes": {
                        "deployment.environment": "development"
                    }
                }
            }
        ],
        "Enrich": [ "WithMachineName", "WithProcessId", "WithThreadId" ]
    },
    "OpenTelemetryConfiguration": {
        "Endpoint": "http://otel-lgtm:4317"
    },
    "MongoDatabaseConfiguration": {
        "ConnectionString": "Server=sqlserver;Database=instaconnect.identity;User Id=sa;Password=password123!;MultipleActiveResultSets=true;TrustServerCertificate=True;",
        "Name": "InstaConnect"
    },
    "CacheConfiguration": {
        "ConnectionString": "redis:6379,password=yourpassword,abortConnect=False"
    },
    "CorsConfiguration": {
        "AllowedOrigins": "gateway-svc:5100"
    },
    "MessageBrokerConfiguration": {
        "Host": "amqp://rabbitmq:5672",
        "Username": "guest",
        "Password": "guest"
    },
    "AccessTokenConfiguration": {
        "Issuer": "http://identity-svc:5200",
        "Audience": "http://gateway-svc:5100",
        "SecurityKey": "6R9f6d1Y4Z$0^8Y&S2e3nF4*G6u7D0#L9K!pT2vW8xZ5@qR7mN3bH6cJ1L0sF4dE8",
        "LifetimeSeconds": 900
    },
    "EmailConfirmationTokenConfiguration": {
        "LifetimeSeconds": 10000
    },
    "ForgotPasswordTokenConfiguration": {
        "LifetimeSeconds": 10000
    },
    "RefreshTokenConfiguration": {
        "LifetimeSeconds": 10000
    },
    "ImageUploadConfiguration": {
        "CloudName": "test",
        "ApiKey": "test",
        "ApiSecret": "test"
    }
}
